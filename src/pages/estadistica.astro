---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import historial from '../Data/historial.json';
import sprint from '../Data/sprint.json';

// --- LÓGICA DE CONSOLIDACIÓN (Mantengo tu código igual) ---
const statsPilotos = {};

function procesarSesion(dataArray) {
  (dataArray || []).forEach((sesion) => {
    const esNombreValido = (n) => n && typeof n === 'string' && !n.includes(':') && !/^\d/.test(n);

    const registrarPiloto = (nombre) => {
      if (esNombreValido(nombre)) {
        if (!statsPilotos[nombre]) {
          statsPilotos[nombre] = { nombre, puntos: 0, victorias: 0, podios: 0, poles: 0, vRapidas: 0 };
        }
        return true;
      }
      return false;
    };

    if (registrarPiloto(sesion.pole)) statsPilotos[sesion.pole].poles += 1;
    const vr = sesion.pilotoVueltaRapida || sesion.vueltaRapida;
    if (registrarPiloto(vr)) statsPilotos[vr].vRapidas += 1;

    if (sesion.resultados) {
      sesion.resultados.forEach((res) => {
        if (registrarPiloto(res.piloto)) {
          statsPilotos[res.piloto].puntos += (res.puntos || 0);
          if (res.pos === 1) statsPilotos[res.piloto].victorias += 1;
          if (res.pos <= 3) statsPilotos[res.piloto].podios += 1;
        }
      });
    }
  });
}

procesarSesion(historial);
procesarSesion(sprint);

const ranking = Object.values(statsPilotos).sort((a, b) => b.puntos - a.puntos);
const maxPuntos = ranking.length > 0 ? ranking[0].puntos : 1;
---
<body class="bg-slate-950 text-white font-sans">

<nav class="bg-slate-950 fixed top-0 w-full bg-[#020c1b]/95 backdrop-blur-xl border-b border-white/5 z-[100]">
    <div class="bg-slate-950 max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="bg-slate-950 flex items-center gap-3 group cursor-pointer">
            <div class="flex flex-col items-start leading-none">
                <span class="font-black italic text-xl tracking-tighter uppercase text-white -skew-x-12">
                    FORMULA <span class="text-red-600">1</span>
                </span>
                <span class="text-[7px] font-mono text-zinc-500 uppercase tracking-[0.4em] ml-1">Statistics Center</span>
            </div>
        </a>

        <div class="hidden md:flex items-center gap-6 text-[11px] font-black uppercase tracking-[0.2em]">
            <a href="/" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Inicio
            </a>
            <a href="/historial" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Historial Carreras
            </a>
            <a href="/sprint" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Sprint
            </a>
            
            <div class="bg-red-600/10 border border-red-600/30 px-4 py-2 rounded-md">
                <span class="text-red-500 font-black italic">Stats Mode Active</span>
            </div>
        </div>

        <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 items-end group outline-none">
            <span class="w-8 h-[2px] bg-white group-hover:bg-red-600 transition-all origin-right" id="line1"></span>
            <span class="w-5 h-[2px] bg-red-600 group-hover:bg-white transition-all" id="line2"></span>
            <span class="w-8 h-[2px] bg-white group-hover:bg-red-600 transition-all origin-right" id="line3"></span>
        </button>
    </div>

    <div id="mobile-menu-content" class="bg-slate-950 fixed inset-0 top-[72px] bg-[#020c1b] z-[90] flex flex-col p-8 transition-all duration-500 translate-x-full md:hidden">
        <div class="flex flex-col gap-8">
            <span class="text-[9px] font-mono text-zinc-600 tracking-[0.5em] uppercase border-b border-zinc-900 pb-2">Analytics System</span>
            
            <a href="/" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Inicio</a>
            <a href="/historial" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Historial</a>
            <a href="/sprint" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Sprint</a>
            
            <div class="bg-slate-950 mt-4 p-4 border-l-2 border-red-600 bg-red-600/5">
                <span class="text-[10px] font-mono text-red-500 uppercase tracking-widest block mb-1">Current Task:</span>
                <span class="text-xl font-black text-white italic uppercase">Global Statistics</span>
            </div>
        </div>
        <div class="mt-auto opacity-10">
            <span class="text-[60px] font-black italic text-white leading-none tracking-tighter">ANALYTICS</span>
        </div>
    </div>
</nav>

<script data-astro-rerun>
    document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu-content');
        const lines = [document.getElementById('line1'), document.getElementById('line2'), document.getElementById('line3')];

        if (!btn || !menu) return;

        const toggleMenu = () => {
            const isOpen = menu.classList.contains('translate-x-0');
            if (isOpen) {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                lines[0].style.transform = 'rotate(0) translateY(0)';
                lines[1].style.opacity = '1';
                lines[2].style.transform = 'rotate(0) translateY(0)';
            } else {
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                lines[0].style.transform = 'rotate(-45deg) translate(-5px, 5px)';
                lines[1].style.opacity = '0';
                lines[2].style.transform = 'rotate(45deg) translate(-5px, -5px)';
            }
        };

        btn.addEventListener('click', toggleMenu);

        // Cerramos el menú si se hace click en un link (evita que quede abierto al volver)
        const links = document.querySelectorAll('.mobile-link');
        links.forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
            });
        });
    });
</script>

  <main class="bg-slate-950 max-w-5xl mx-auto pt-32 pb-20 px-4">
    <header id="inicio" class="bg-slate-950 mb-16 relative py-20 overflow-hidden "> 
    <img 
        src="/Fotos/fondo-f1.png" 
        class="bg-slate-950 absolute inset-0 w-full h-full object-cover opacity-20 z-0 pointer-events-none" 
        alt="Fondo Sprint"
        
    />
<div class="absolute inset-0 z-[1] bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-zinc-900/0 via-black/80 to-black pointer-events-none"></div>

    <div class="absolute inset-0 z-[2] opacity-[0.03] pointer-events-none bg-[url('data:image/svg+xml;base64,')] bg-center"></div>

    <div class="absolute top-10 left-10 w-16 h-16 border-t-2 border-l-2 border-zinc-800 pointer-events-none opacity-40"></div>
    <div class="absolute top-10 right-10 w-16 h-16 border-t-2 border-r-2 border-zinc-800 pointer-events-none opacity-40"></div>
    <div class="relative z-10 text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white -skew-x-15 leading-tight">
            ESTADISTICAS 
            <span class="block md:inline text-red-600 -skew-x-15 drop-shadow-[0_0_20px_rgba(220,38,38,0.6)]">
                PILOTOS
            </span>
        </h1>
        <div class="mt-8 mb-4 flex justify-center items-center gap-4 reveal-on-scroll">
            <span class="flex-1 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent max-w-[200px]"></span>
            
                
                
            </div>
            <span class="flex-1 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent max-w-[200px]"></span>
        </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-red-950 via-red-600 to-red-950 opacity-80 shadow-[0_0_20px_rgba(220,38,38,0.5)]"></div>
</header>

    <section class="bg-slate-950 max-w-5xl mx-auto px-6 mb-20">
      <div class="flex flex-col gap-8">
        {ranking.map((piloto, index) => {
          const percentage = (piloto.puntos / maxPuntos) * 100;
          return (
            <div class="reveal-item group">
              <div class="flex justify-between items-end mb-2">
                <div class="flex items-center gap-4">
                  <span class="text-2xl font-black italic text-zinc-800 group-hover:text-red-600 transition-colors">#{index + 1}</span>
                  <div>
                    <h2 class="text-xl font-black uppercase italic text-white leading-none">{piloto.nombre}</h2>
                    <div class="flex gap-2 mt-2">
                        <span class="text-[9px] font-bold bg-zinc-900 border border-zinc-800 px-2 py-0.5 rounded text-zinc-400">{piloto.victorias}V</span>
                        <span class="text-[9px] font-bold bg-zinc-900 border border-zinc-800 px-2 py-0.5 rounded text-zinc-400">{piloto.podios}P</span>
                        {piloto.vRapidas > 0 && <span class="text-[9px] font-bold bg-green-600/10 border border-green-600/20 px-2 py-0.5 rounded text-green-500">{piloto.vRapidas}VR</span>}
                    </div>
                  </div>
                </div>
                <div class="text-right">
                  <span class="text-3xl font-mono font-black text-red-600 italic leading-none">{piloto.puntos}</span>
                  <span class="text-[10px] font-black text-zinc-500 block uppercase">Puntos</span>
                </div>
              </div>
              
              <div class="h-5 bg-zinc-950 rounded-full border border-zinc-900 overflow-hidden relative shadow-inner">
  <div 
      class="f1-telemetry-bar h-full bg-gradient-to-r from-red-950 via-red-600 to-red-500 relative transition-all duration-1000 ease-out" 
      data-p={percentage} 
      style="width: 0%; transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);"
  >
    <div class="absolute right-0 top-0 h-full w-1 bg-white shadow-[0_0_15px_4px_rgba(220,38,38,0.8),0_0_20px_2px_rgba(255,255,255,0.6)] z-10"></div>

    <div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent opacity-50"></div>
    
    <div class="absolute inset-0 bg-white/5 animate-pulse"></div>
  </div>
</div>
              </div>
            </div>
          )
        })}
      </div>
    </section>
<script data-astro-rerun>
    // Función centralizada de animación
    function animarBarras() {
        // Buscamos todas las barras
        const bars = document.querySelectorAll('.f1-telemetry-bar');
        
        // Pequeño delay para que la transición de página termine y se vea el efecto "filling"
        setTimeout(() => {
            bars.forEach(bar => {
                const targetWidth = bar.getAttribute('data-p');
                if (targetWidth) {
                    bar.style.width = targetWidth + '%';
                }
            });
        }, 100); // 100ms es suficiente para que el DOM esté listo
    }

    // Se dispara en la carga inicial
    animarBarras();

    // Se dispara cada vez que Astro cambia de página (View Transitions)
    document.addEventListener('astro:page-load', animarBarras);
</script>
    <section class="bg-slate-950 max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 pb-20">
        <div class=" border-t-4 border-purple-600 p-6 rounded-xl border border-zinc-900">
            <h3 class="text-xs font-black uppercase text-zinc-500 mb-6 italic tracking-widest italic flex items-center gap-2">
                <span class="w-2 h-2 bg-purple-600 rounded-full"></span> Poles
            </h3>
            {ranking.filter(p => p.poles > 0).map(p => (
                <div class="bg-slate-950 mb-4">
                    <div class="flex justify-between text-[11px] font-bold uppercase mb-1">
                        <span class="text-zinc-300">{p.nombre}</span>
                        <span class="text-white">{p.poles}</span>
                    </div>
                    <div class="h-1 bg-zinc-900 rounded-full overflow-hidden">
                        <div class="h-full bg-purple-600" style={`width: ${(p.poles / Math.max(...ranking.map(x => x.poles), 1)) * 100}%`}></div>
                    </div>
                </div>
            ))}
        </div>

        <div class="bg-slate-950 border-t-4 border-red-600 p-6 rounded-xl border border-zinc-900">
            <h3 class="text-xs font-black uppercase text-zinc-500 mb-6 italic tracking-widest flex items-center gap-2">
                <span class="w-2 h-2 bg-red-600 rounded-full"></span> Victorias
            </h3>
            {ranking.filter(p => p.victorias > 0).map(p => (
                <div class="mb-4">
                    <div class="flex justify-between text-[11px] font-bold uppercase mb-1">
                        <span class="text-zinc-300">{p.nombre}</span>
                        <span class="text-white">{p.victorias}</span>
                    </div>
                    <div class="h-1 bg-zinc-900 rounded-full overflow-hidden">
                        <div class="h-full bg-red-600" style={`width: ${(p.victorias / Math.max(...ranking.map(x => x.victorias), 1)) * 100}%`}></div>
                    </div>
                </div>
            ))}
        </div>

        <div class="bg-slate-950 border-t-4 border-yellow-500 p-6 rounded-xl border border-zinc-900">
            <h3 class="text-xs font-black uppercase text-zinc-500 mb-6 italic tracking-widest flex items-center gap-2">
                <span class="w-2 h-2 bg-yellow-500 rounded-full"></span> Podios
            </h3>
            {ranking.filter(p => p.podios > 0).map(p => (
                <div class="mb-4">
                    <div class="flex justify-between text-[11px] font-bold uppercase mb-1">
                        <span class="text-zinc-300">{p.nombre}</span>
                        <span class="text-white">{p.podios}</span>
                    </div>
                    <div class="h-1 bg-zinc-900 rounded-full overflow-hidden">
                        <div class="h-full bg-yellow-500" style={`width: ${(p.podios / Math.max(...ranking.map(x => x.podios), 1)) * 100}%`}></div>
                    </div>
                </div>
            ))}
        </div>

        <div class=" border-t-4 border-green-500 p-6 rounded-xl border border-zinc-900">
            <h3 class="text-xs font-black uppercase text-zinc-500 mb-6 italic tracking-widest flex items-center gap-2">
                <span class="w-2 h-2 bg-green-500 rounded-full"></span> V. Rapidas
            </h3>
            {ranking.filter(p => p.vRapidas > 0).map(p => (
                <div class="mb-4">
                    <div class="flex justify-between text-[11px] font-bold uppercase mb-1">
                        <span class="text-zinc-300">{p.nombre}</span>
                        <span class="text-white">{p.vRapidas}</span>
                    </div>
                    <div class="h-1 bg-zinc-900 rounded-full overflow-hidden">
                        <div class="h-full bg-green-500" style={`width: ${(p.vRapidas / Math.max(...ranking.map(x => x.vRapidas), 1)) * 100}%`}></div>
                    </div>
                </div>
            ))}
        </div>
    </section>
  </main>
</Layout>

<script data-astro-rerun>
    document.addEventListener('astro:page-load', () => {
        // Animación de barras
        const bars = document.querySelectorAll('.f1-telemetry-bar');
        setTimeout(() => {
            bars.forEach(bar => {
                const val = bar.getAttribute('data-p');
                bar.style.width = val + '%';
            });
        }, 300);

        // Menú Móvil
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu-content');
        if (btn && menu) {
            btn.addEventListener('click', () => {
                const isOpen = menu.classList.contains('translate-x-0');
                menu.classList.toggle('translate-x-0', !isOpen);
                menu.classList.toggle('translate-x-full', isOpen);
            });
        }
    });
</script>
<style>
    /* Animación extra para el brillo de las barras */
    @keyframes shimmer {
        100% { transform: translateX(100%); }
    }
    
    /* Aseguramos que el contenedor de la página tenga el fondo correcto */
    
</style>

</body>