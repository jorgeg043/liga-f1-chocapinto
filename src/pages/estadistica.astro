</section>

<script data-astro-rerun>
    // Función centralizada de animación
    function animarBarras() {
        // Buscamos todas las barras
        const bars = document.querySelectorAll('.f1-telemetry-bar');
        
        // Pequeño delay para que la transición de página termine y se vea el efecto "filling"
        setTimeout(() => {
            bars.forEach(bar => {
                const targetWidth = bar.getAttribute('data-p');
                if (targetWidth) {
                    bar.style.width = targetWidth + '%';
                }
            });
        }, 100); // 100ms es suficiente para que el DOM esté listo
    }

    // Se dispara en la carga inicial
    animarBarras();

    // Se dispara cada vez que Astro cambia de página (View Transitions)
    document.addEventListener('astro:page-load', animarBarras);
</script>
