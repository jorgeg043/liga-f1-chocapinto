---
import '../styles/global.css';
import pilotos from '../Data/pilotos.json';
import sprintData from '../Data/sprint.json';
import sprint from '../Data/sprint.json';
import { ClientRouter } from 'astro:transitions';

const ultimaFechaSprint = 1;
const fechasSprint = Array.from({ length: ultimaFechaSprint }, (_, i) => ultimaFechaSprint - i);
const obtenerInfoPiloto = (nombre) => {
    return pilotos.find(p => p.nombre === nombre) || { escuderia: "S/D" };
};

const logos = {
  "Mercedes Benz": "/Fotos/logo-mercedes.png",
  "Alpine": "/Fotos/logo-alpine.png",
  "Red Bull": "/Fotos/logo-redbull.png",
  "Ferrari": "/Fotos/logo-ferrari.png"
};
---


<style>
    .show-dropdown {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) !important;
    }
    .rotate-arrow {
        transform: rotate(180deg) !important;
    }
@keyframes latido {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.25); /* Se agranda un 10% */
  }
}

.animate-latido {
  animation: latido 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes latido-pro {
  0%, 100% {
    transform: scale(1);
    filter: grayscale(10%) opacity(50%) blur(1px);
    /* Sombra tenue cuando está "apagado" */
    filter: drop-shadow(0 0 0px rgba(0,0,0,0));
  }
  50% {
    transform: scale(1.25); /* Se agranda un 15% */
    filter: grayscale(0%) opacity(100%) blur(0px);
    /* Brillo rojo estilo F1 cuando se agranda */
    filter: drop-shadow(0 0 15px rgba(220, 38, 38, 0.6));
  }
}

.animate-latido-color {
  animation: latido-pro 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}


</style>



<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Historial Sprint - Liga Chocapinto</title>
    <ClientRouter />
</head>
<body class="bg-slate-950 text-white font-sans">

    <nav class="fixed top-0 w-full bg-[#020c1b]/95 backdrop-blur-xl border-b border-white/5 z-[100]">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="flex items-center gap-3 group cursor-pointer">
            <div class="flex flex-col items-start leading-none">
                <span class="font-black italic text-xl tracking-tighter uppercase text-white -skew-x-12">
                    FORMULA <span class="text-red-600">1</span>
                </span>
                <span class="text-[7px] font-mono text-zinc-500 uppercase tracking-[0.4em] ml-1">Sprint Session</span>
            </div>
        </a>

        <div class="hidden md:flex items-center gap-6 text-[11px] font-black uppercase tracking-[0.2em]">
            <a href="/" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Inicio
            </a>
            <a href="/historial" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Historial Carreras
            </a>
            <a href="/estadistica" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Estadística
            </a>
            
            <div class="bg-red-600/10 border border-red-600/30 px-4 py-2 rounded-md">
                <span class="text-red-500">Sprint Mode Active</span>
            </div>
        </div>

        <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 items-end group outline-none">
            <span class="w-8 h-[2px] bg-white group-hover:bg-red-600 transition-all origin-right" id="line1"></span>
            <span class="w-5 h-[2px] bg-red-600 group-hover:bg-white transition-all" id="line2"></span>
            <span class="w-8 h-[2px] bg-white group-hover:bg-red-600 transition-all origin-right" id="line3"></span>
        </button>
    </div>

    <div id="mobile-menu-content" class="fixed inset-0 top-[72px] bg-[#020c1b] z-[90] flex flex-col p-8 transition-all duration-500 translate-x-full md:hidden">
        <div class="flex flex-col gap-8">
            <span class="text-[9px] font-mono text-zinc-600 tracking-[0.5em] uppercase border-b border-zinc-900 pb-2">Quick Navigation</span>
            
            <a href="/" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Inicio</a>
            <a href="/historial" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Historial</a>
            <a href="/estadistica" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Estadística</a>
            
            <div class="mt-4 p-4 border-l-2 border-red-600 bg-red-600/5">
                <span class="text-[10px] font-mono text-red-500 uppercase tracking-widest block mb-1">Current Session:</span>
                <span class="text-xl font-black text-white italic uppercase">Sprint Results</span>
            </div>
        </div>
    </div>
</nav>

<script data-astro-rerun>
    document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu-content');
        const lines = [document.getElementById('line1'), document.getElementById('line2'), document.getElementById('line3')];

        if (!btn || !menu) return;

        const toggleMenu = () => {
            const isOpen = menu.classList.contains('translate-x-0');
            if (isOpen) {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                lines[0].style.transform = 'rotate(0) translateY(0)';
                lines[1].style.opacity = '1';
                lines[2].style.transform = 'rotate(0) translateY(0)';
            } else {
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                lines[0].style.transform = 'rotate(-45deg) translate(-5px, 5px)';
                lines[1].style.opacity = '0';
                lines[2].style.transform = 'rotate(45deg) translate(-5px, -5px)';
            }
        };

        btn.addEventListener('click', toggleMenu);
    });
</script>
 
    <main class="max-w-5xl mx-auto pt-32 pb-20 px-4">
       
      <header id="inicio" class="mb-16 relative py-20 overflow-hidden "> 
    <img 
        src="/Fotos/fondo-f1.png" 
        class="absolute inset-0 w-full h-full object-cover opacity-20 z-0 pointer-events-none" 
        alt="Fondo Sprint"
        
    />
<div class="absolute inset-0 z-[1] bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-zinc-900/0 via-black/80 to-black pointer-events-none"></div>

    <div class="absolute inset-0 z-[2] opacity-[0.03] pointer-events-none bg-[url('data:image/svg+xml;base64,')] bg-center"></div>

    <div class="absolute top-10 left-10 w-16 h-16 border-t-2 border-l-2 border-zinc-800 pointer-events-none opacity-40"></div>
    <div class="absolute top-10 right-10 w-16 h-16 border-t-2 border-r-2 border-zinc-800 pointer-events-none opacity-40"></div>
    <div class="relative z-10 text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white -skew-x-15 leading-tight">
            HISTORIAL 
            <span class="block md:inline text-red-600 -skew-x-15 drop-shadow-[0_0_20px_rgba(220,38,38,0.6)]">
                SPRINT
            </span>
        </h1>
        <div class="mt-8 mb-4 flex justify-center items-center gap-4 reveal-on-scroll">
            <span class="flex-1 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent max-w-[200px]"></span>
            <div class="flex items-center justify-center gap-1.5 bg-zinc-950 px-4 py-1.5 rounded-full border border-zinc-800 shadow-inner">
                <span class="w-1.5 h-1.5 bg-red-600 rounded-full animate-pulse"></span>
                <p class="text-zinc-400 font-mono text-[9px] uppercase tracking-[0.5em]">
                    RESULTADOS POR FECHA
                </p>
            </div>
            <span class="flex-1 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent max-w-[200px]"></span>
        </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-red-950 via-red-600 to-red-950 opacity-80 shadow-[0_0_20px_rgba(220,38,38,0.5)]"></div>
</header>




        {sprintData.map((fecha, index) => (
    <div class="mb-32 reveal-item" style={`transition-delay: ${index * 150}ms;`}>
        
        <div class="flex flex-col md:flex-row justify-between items-end border-b-2 border-zinc-900 pb-8 mb-10 gap-6 relative">
            
            
            <div class="w-full md:w-auto">
                <div class="flex items-center gap-3 mb-4">
                    <span class="bg-red-600 text-white text-[10px] font-black px-3 py-1 rounded-sm uppercase italic tracking-widest shadow-[0_0_15px_rgba(220,38,38,0.4)] animate-bounce">
                        SPRINT {fecha.id || '01'}
                    </span>
                    <div class="h-[1px] w-10 bg-zinc-800"></div>
                    <span class="text-zinc-500 font-mono text-[10px] uppercase tracking-[0.3em]">
                        {fecha.fecha}
                    </span>
                </div>
                
                <h2 class="text-5xl md:text-6xl font-black uppercase italic tracking-tighter text-white -skew-x-12">
                    {fecha.gp} 
                    <span class="text-zinc-600 text-2xl block md:inline md:ml-4 not-italic font-light tracking-normal">
                        // {fecha.circuito}
                    </span>
                </h2>
            </div>
            
            <div class="text-right hidden md:block">
                <p class="text-[10px] font-mono text-zinc-500 uppercase tracking-[0.4em] mb-2">Estados</p>
                <div class="flex items-center gap-2 justify-end">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                    <p class="font-black italic text-2xl text-white uppercase tracking-tighter">RESULTADOS OFICIALES</p>
                </div>
            </div>
        </div>

        <div class="bg-[#020c1b]/60 rounded-xl border border-zinc-900 overflow-hidden backdrop-blur-xl shadow-2xl relative">
            
            <div class="absolute top-0 right-0 w-16 h-16 border-t border-r border-zinc-800 pointer-events-none"></div>
            
            <div class="overflow-x-auto no-scrollbar">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-zinc-950/80 border-b border-zinc-900">
                        <tr class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-500">
                            <th class="px-8 py-5 text-center w-24">POS</th>
                            <th class="px-6 py-5">INFO PILOTO</th>
                            <th class="px-6 py-5 text-center w-32">SESSION_DATA</th>
                            <th class="px-8 py-5 text-right w-28 text-white">PUNTOS</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-zinc-900">
                        {sprint.map((f_data) => (
                            f_data.resultados.sort((a, b) => a.pos - b.pos).map((res, resIndex) => {
                                const info = obtenerInfoPiloto(res.piloto);
                                return (
                                    <tr class="group hover:bg-white/[0.02] transition-all duration-500 relative">
                                        
                                        <td class="px-8 py-6 text-center relative">
                                            <div class="absolute left-0 top-1/4 h-1/2 w-1 bg-red-600 opacity-30 group-hover:opacity-100 transition-opacity"></div>
                                            <span class="text-3xl font-mono font-black italic text-zinc-800 group-hover:text-red-500 transition-colors duration-500 leading-none">
                                                {res.pos < 10 ? `0${res.pos}` : res.pos}
                                            </span>
                                        </td>

                                        <td class="px-6 py-6">
                                            <div class="flex items-center gap-6">
                                                <div class="relative flex-shrink-0">
                                                    <img 
                                                        src={`/Fotos/perfil-${res.piloto.toLowerCase()}.jpg`} 
                                                        class="w-14 h-14 rounded-full object-cover border-2 border-zinc-800 group-hover:border-red-600 transition-all duration-500 shadow-xl z-10 relative animate-pulse"
                                                        alt={res.piloto}
                                                    />
                                                    <div class="absolute inset-0 rounded-full bg-red-600/20 blur-md opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                                </div>
                                                
                                                <div class="flex items-center gap-5">
                                                    <img src={logos[info.escuderia]} class="w-12 h-12 object-contain filter grayscale-60 group-hover:grayscale-0 opacity-40 group-hover:opacity-100 transition-all duration-500" alt={info.escuderia} />
                                                    <div>
                                                        <p class="font-black uppercase italic text-xl leading-none mb-1 text-zinc-300 group-hover:text-white transition-colors tracking-tighter">
                                                            {res.piloto}
                                                        </p>
                                                        <p class="text-[9px] text-zinc-600 font-mono uppercase tracking-widest group-hover:text-red-500 transition-colors">
                                                            {info.escuderia}
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="px-6 py-6 text-center w-32">
                                            <div class="flex gap-2 justify-center">
                                                {res.piloto === f_data.pole && (
                                                    <span class="bg-red-600 text-white text-[9px] px-2 py-1 rounded-sm font-black shadow-[0_0_10px_rgba(220,38,38,0.3)] animate-pulse">P</span>
                                                )}
                                                {res.nota === "VR" && (
                                                    <span class="bg-blue-600 text-white text-[9px] px-2 py-1 rounded-sm font-black shadow-[0_0_10px_rgba(37,99,235,0.3)] animate-pulse">V.R.</span>
                                                )}
                                            </div>
                                        </td>

                                        <td class="px-8 py-6 text-right w-28">
                                            <div class="relative inline-block">
                                                <span class="text-3xl font-mono font-black text-white italic tracking-tighter group-hover:text-red-500 transition-all duration-300">
                                                    {res.puntos}
                                                </span>
                                                <span class="absolute -top-1 -right-4 text-[8px] font-black text-zinc-600 italic">PTS</span>
                                            </div>
                                        </td>

                                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/[0.01] to-transparent w-full h-full -translate-x-full group-hover:animate-[scan_3s_linear_infinite] pointer-events-none"></div>
                                    </tr>
                                );
                            })
                        ))}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
))}

    </main>
<section id="galeria-sprint" class="mt-20 pb-20 px-4 max-w-6xl mx-auto">
    <div class="reveal-on-scroll text-center mb-16">
        <h2 class="text-sm font-black mb-4 uppercase tracking-[0.4em] text-zinc-400">
            Datos <span class="text-red-600">Sprint</span> Archivo
        </h2>
        <h3 class="text-4xl font-black uppercase italic text-white tracking-tighter">
            GALERÍA DE <span class="text-red-600">SPRINTS</span>
        </h3>
    </div>

    <div class="space-y-24">
        {fechasSprint.map((f) => (
            <div class="reveal-item group relative" style={`transition-delay: 100ms;`}>
                
                <div class="absolute -left-4 md:-left-12 top-0 flex flex-col items-center">
                    <span class="text-[10px] font-black text-zinc-600 uppercase vertical-text tracking-[0.5em] rotate-180">
                        FAST_TRACK
                    </span>
                    <div class="w-[1px] h-20 bg-zinc-800 my-4"></div>
                    <span class="text-2xl font-mono font-black text-red-600 italic">
                        S{f < 10 ? `0${f}` : f}
                    </span>
                </div>

                <div class="ml-8 md:ml-0 bg-[#020c1b]/50 border border-zinc-900 rounded-xl overflow-hidden hover:border-red-600/30 transition-all duration-500 shadow-2xl">
                    
                    <div class="bg-zinc-950 px-6 py-4 border-b border-zinc-900 flex justify-between items-center">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></div>
                            <h4 class="text-xs font-black uppercase tracking-widest text-zinc-300">
                                SPRINT: <span class="text-white">FECHA {f}</span>
                            </h4>
                        </div>
                        <span class="text-[10px] font-mono text-zinc-600">TYPE: SPRINT_SESSION</span>
                    </div>

                    <div class="relative p-2 md:p-4 bg-zinc-900/20">
                        <div class="absolute top-6 left-6 w-8 h-8 border-t-2 border-l-2 border-red-600/50 z-20"></div>
                        <div class="absolute bottom-6 right-6 w-8 h-8 border-b-2 border-r-2 border-red-600/50 z-20"></div>

                        <div class="relative overflow-hidden rounded-lg group-hover:shadow-[0_0_50px_rgba(220,38,38,0.15)] transition-all">
                            <img 
                                src={`/Fotos/resultados-sprint-f${f}.jpg`} 
                                class="w-full h-auto object-contain max-h-[80vh] transition-transform duration-700 group-hover:scale-[1.02]" 
                                alt={`Resultados Sprint Fecha ${f}`}
                                loading="lazy"
                            />
                            
                            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-red-600/[0.03] to-transparent h-[200%] w-full -translate-y-full group-hover:animate-[scan_4s_linear_infinite] pointer-events-none"></div>
                        </div>
                    </div>

                    <div class="px-6 py-3 bg-zinc-950/80 text-right">
                        <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest">
                            Sprint Data Verified // LC-VT-S{f}
                        </p>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    .vertical-text {
        writing-mode: vertical-rl;
    }

    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(200%); }
    }
</style>



<style>
    #typing-text {
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        /* Animación: escribir (4s), pausa, borrar, pausa */
        animation: typing 5s steps(30) infinite;
        width: 0;
        border-right: 3px solid transparent; /* Actúa como el cursor */
    }

    @keyframes typing {
        0% { width: 0; }
        30%, 70% { width: 100%; } /* Se queda escrito del 30% al 70% del tiempo */
        90%, 100% { width: 0; }    /* Se borra al final */
    }

    .animate-cursor {
        animation: blink 0.8s step-end infinite;
    }

    @keyframes blink {
        from, to { opacity: 1; }
        50% { opacity: 0; }
    }
</style>
</body>
</html>