---
import '../styles/global.css';
import pilotos from '../Data/pilotos.json';
import sprintData from '../Data/sprint.json';
import { ClientRouter } from 'astro:transitions';

const obtenerInfoPiloto = (nombre) => {
    return pilotos.find(p => p.nombre === nombre) || { escuderia: "S/D" };
};
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Historial Sprint - Liga Chocapinto</title>
    <ClientRouter />
</head>
<body class="bg-slate-950 text-white font-sans">

    <nav class="fixed top-0 w-full bg-zinc-900/80 backdrop-blur-md border-b border-zinc-800 z-50">
        <div class="max-w-5xl mx-auto px-6 py-5 flex justify-between items-center">
            <a href="/" class="font-black italic text-xl tracking-tighter uppercase text-white -skew-x-15">
                FORMULA <span class="text-red-600 italic">1</span>
            </a>
            <div class="flex gap-8 font-black uppercase  text-xs tracking-widest text-zinc-100">
                <a href="/" class="hover:text-white transition-colors">Inicio</a>
                <a href="/historial" class="hover:text-white transition-colors">Carreras</a>
                <a href="/sprint" class="text-red-600 underline underline-offset-8 decoration-2">Sprint</a>
            </div>
        </div>
    </nav>
 
    <main class="max-w-4xl mx-auto pt-32 pb-20 px-4">
       
      <header class="mb-16 relative py-20 overflow-hidden border-b-4 border-red-950"> 
    <img 
        src="/Fotos/fondo-f1.png" 
        class="absolute inset-0 w-full h-full object-cover opacity-20 z-0 pointer-events-none" 
        alt="Fondo Sprint"
    />

    <div class="relative z-10 text-center">
        <h1 class="text-5xl font-black uppercase italic tracking-tighter text-white -skew-x-15">
            Historial de <span class="text-red-600 -skew-x-15">Sprint</span>
        </h1>
        <p class="text-zinc-300 font-mono text-xs uppercase tracking-[0.4em] mt-2">
            Resultados por fecha
        </p>
    </div>
</header>

<div class="flex flex-col items-center justify-center py-20 bg-zinc-800 rounded-3xl border border-zinc-100/50 shadow-2xl overflow-hidden">
    <div class="relative">
        <h2 id="typing-text" class="text-4xl md:text-6xl font-black uppercase italic tracking-tighter text-white font-mono">
            <span class="text-red-600">"Próximamente...</span> 01/05/2026"
        </h2>
        
    </div>
</div>
