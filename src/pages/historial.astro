---
// Mantener los imports iguales arriba
import '../styles/global.css';
import pilotos from '../Data/pilotos.json';
import historial from '../Data/historial.json';
import { ClientRouter } from 'astro:transitions';
const logos = {
  "Mercedes Benz": "/Fotos/logo-mercedes.png",
  "Alpine": "/Fotos/logo-alpine.png",
  "Red Bull": "/Fotos/logo-redbull.png",
  "Ferrari": "/Fotos/logo-ferrari.png"
};

const obtenerInfoPiloto = (nombre) => {
    return pilotos.find(p => p.nombre === nombre) || { escuderia: "S/D" };
};
---

<html lang="es">
    <head>
       <meta charset="utf-8" />
    <title>Historial - Liga F1 Chocapinto</title>
    <ClientRouter /> </head>
</head>
    <body class="bg-slate-950 text-white font-sans">
        
        <nav class="fixed top-0 w-full bg-zinc-900/80 backdrop-blur-md border-b border-zinc-800 z-50">
            <div class="max-w-5xl mx-auto px-22 py-5 flex justify-between items-center">
                <a href="/" class="font-black italic text-xl tracking-tighter uppercase text-white -skew-x-15">
                    FORMULA <span class="text-red-600">1</span>
                </a>
                <a href="/" class="text-[10px] font-black uppercase tracking-widest hover:text-red-500 transition-colors">← Volver al Inicio</a>
            </div>
        </nav>

        <main class="max-w-5xl mx-auto py-24 px-4 pt-32">
            <header class="relative overflow-hidden border-b-4 border-red-600 mb-12 pb-11 pt-20">
    <div class="absolute inset-0 z-0 pointer-events-none">
        <img 
            src="/Fotos/fondo-f1.png" 
            alt="" 
            class="w-full h-full object-cover opacity-60" 
        />
        <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/50 to-zinc-950"></div>
    </div>

    <div class="relative z-10 px-2">
        <h1 class="text-5xl font-black uppercase italic tracking-tighter text-white -skew-x-12">
            Archivo de <span class="text-red-600 -skew-x-12">Carreras</span>
        </h1>
        <p class="text-zinc-400 font-mono text-xs mt-2 font-bold uppercase tracking-[0.3em]">
            Resultados por Fecha
        </p>
    </div>
</header>

            <div class="space-y-32">
                {historial.map((fecha) => (
                    <section class="mb-32">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6">
        <div class="border-l-4 border-red-600 pl-6">
            <span class="text-zinc-500 font-mono text-xs font-bold uppercase tracking-widest">Fecha {fecha.id}</span>
            <h2 class="text-4xl font-black uppercase italic tracking-tight text-white">{fecha.gp}</h2>
            <p class="text-zinc-400 text-sm font-bold">{fecha.circuito} • {fecha.fecha}</p>
        </div>
        
        <div class="flex gap-6 border-t border-zinc-800 md:border-t-0 pt-4 md:pt-0">
            <div class="flex gap-6 border-t border-zinc-800 md:border-t-0 pt-4 md:pt-0">
    <div>
        <p class="text-[9px] text-zinc-0 font-black uppercase tracking-widest mb-1">Qualy Record</p>
        <p class="text-sm font-mono font-bold text-red-500">{fecha.tiempoPole}</p>
    </div>
    <div>
        <p class="text-[9px] text-zinc-0 font-black uppercase tracking-widest mb-1">Vuelta Rápida</p>
        <p class="text-sm font-mono font-bold text-blue-500">{fecha.tiempoVR}</p>
    </div>
    <div>
        <p class="text-[9px] text-zinc-0 font-black uppercase tracking-widest mb-1">Duración Total</p>
        <p class="text-sm font-mono font-bold text-zinc-300">{fecha.duracion}</p>
    </div>
</div>
        </div>
    </div>






    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        
        <div class="lg:col-span-4 bg-zinc-900 rounded-3xl border border-zinc-800 p-8 flex flex-col items-center justify-between group shadow-xl relative overflow-hidden transition-all duration-300 hover:scale-[1.02] hover:z-10 hover:border-red-600/30 transform-gpu">
            <div class="absolute inset-0 bg-red-950/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative z-10 w-full flex flex-col items-center flex-grow justify-center">
                <img 
                    src={fecha.imagen} 
                    class="w-auto h-full max-h-[350px] object-contain grayscale opacity-30 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" 
                    alt={`Circuito de ${fecha.gp}`} 
                />
            </div>
            
            <div class="relative z-10 w-full text-center mt-8 border-t border-zinc-800 pt-6">
                <p class="text-[10px] text-zinc-500 font-mono tracking-[0.4em] uppercase mb-1">Circuito oficial</p>
                <p class="text-xl font-black text-white uppercase tracking-tight italic">{fecha.gp}</p>
            </div>
        </div>

        <div class="lg:col-span-8 bg-zinc-900 rounded-3xl border border-zinc-800 overflow-hidden shadow-2xl flex flex-col justify-between transition-all duration-300 hover:scale-[1.02] hover:z-10 hover:border-red-600/30 transform-gpu">
            <table class="w-full text-left">
                <thead class="bg-zinc-800 text-zinc-250 uppercase text-[10px] font-black tracking-widest">
                    <tr>
                        <th class="px-6 py-5 text-center w-20">Pos</th>
                        <th class="px-6 py-5">Piloto / Escudería</th>
                        <th class="px-6 py-5 text-center">Extra</th>
                        <th class="px-6 py-5 text-right w-24">Pts</th>
                    </tr>
                </thead>
                
                <tbody class="divide-y divide-zinc-800/50">
                    { [...fecha.resultados].sort((a, b) => a.pos - b.pos).map((res) => {
                        const info = obtenerInfoPiloto(res.piloto);
                        return (
                            <tr class="hover:bg-white/[0.15] group transition-colors">
                                <td class={`px-6 py-5 text-center font-black italic text-3xl transition-colors ${res.pos === 1 ? 'text-yellow-500' : 'text-zinc-800 group-hover:text-zinc-100'}`}>
                                    {res.pos}
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-4">
                                        <img src={logos[info.escuderia]} class="w-7 h-7 object-contain opacity-70 group-hover:opacity-100 transition-opacity" alt={info.escuderia} />
                                        <div>
                                            <p class="font-black text-white uppercase tracking-tighter text-lg leading-none mb-1">{res.piloto}</p>
                                            <p class="text-[9px] text-zinc-500 font-bold uppercase tracking-widest leading-none">{info.escuderia}</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-center">
                                    <div class="flex gap-2 justify-center">
                                        {res.piloto === fecha.pole && <span class="bg-red-600/20 text-red-500 text-[9px] px-2 py-0.5 rounded font-black border border-red-600/30">P</span>}
                                        {res.piloto === fecha.vueltaRapida && <span class="bg-blue-600/20 text-blue-500 text-[9px] px-2 py-0.5 rounded font-black border border-blue-600/30">VR</span>}
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-right font-mono font-black text-2xl text-zing-300 italic">
                                    {res.puntos}
                                </td>
                            </tr>
                        );
                    })}
                </tbody>
            </table>
            
            <div class="bg-zinc-800/30 py-3 px-6 text-center border-t border-zinc-800/50">
                <p class="text-[9px] text-zinc-600 font-mono uppercase tracking-[0.3em]">Puntaje Oficial de la Fecha</p>
            </div>
        </div>
    </div>

</section>


<section class="mt-20 pt-10 border-t border-zinc-800 px-4">
   <h2 class="text-2xl font-black uppercase italic mb-6">Galería de <span class="text-red-600">Resultados</span></h2>
    
    <div class="relative group w-full max-w-[90%] mx-auto"> 
        <div id="slider-resultados" class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar scroll-smooth rounded-xl bg-zinc-900/50">
            
            <div class="min-w-full snap-center flex justify-center items-center">
                <img 
                    src="/Fotos/resultados-fecha1.jpg" 
                    class="w-full h-auto max-h-[80vh] object-contain rounded-xl border border-zinc-800 shadow-2xl" 
                    alt="Resultados Fecha 1" 
                />
            </div>           
            
        </div>
    </div>
</section>


                ))}
            </div>
        </main>
    </body>
</html>