---
// Mantener los imports iguales arriba
import '../styles/global.css';
import pilotos from '../Data/pilotos.json';
import historial from '../Data/historial.json';
import { ClientRouter } from 'astro:transitions';
const ultimaFecha = 4;
const fechas = Array.from({ length: ultimaFecha }, (_, i) => ultimaFecha - i);
const carreras = [...historial].reverse();
const logos = {
  "Mercedes Benz": "/Fotos/logo-mercedes.png",
  "Alpine": "/Fotos/logo-alpine.png",
  "Red Bull": "/Fotos/logo-redbull.png",
  "Ferrari": "/Fotos/logo-ferrari.png",
  "Williams": "/Fotos/logo-williams.png",
};

const obtenerInfoPiloto = (nombre) => {
    return pilotos.find(p => p.nombre === nombre) || { escuderia: "S/D" };
};
---

<style>
    .show-dropdown {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) !important;
    }
    .rotate-arrow {
        transform: rotate(180deg) !important;
    }
@keyframes latido {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.25); /* Se agranda un 10% */
  }
}

.animate-latido {
  animation: latido 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes latido-pro {
  0%, 100% {
    transform: scale(1);
    filter: grayscale(10%) opacity(50%) blur(1px);
    /* Sombra tenue cuando está "apagado" */
    filter: drop-shadow(0 0 0px rgba(0,0,0,0));
  }
  50% {
    transform: scale(1.25); /* Se agranda un 15% */
    filter: grayscale(0%) opacity(100%) blur(0px);
    /* Brillo rojo estilo F1 cuando se agranda */
    filter: drop-shadow(0 0 15px rgba(220, 38, 38, 0.6));
  }
}

.animate-latido-color {
  animation: latido-pro 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}


</style>



<html lang="es">
    <head>
       <meta charset="utf-8" />
    <title>Historial - Liga F1 Chocapinto</title>
    <ClientRouter /> </head>
</head>
    <body class="bg-slate-950 text-white font-sans">
        
        <nav class="fixed top-0 w-full bg-[#020c1b]/95 backdrop-blur-xl border-b border-white/5 z-[100]">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <a href="/" class="flex items-center gap-3 group cursor-pointer">
            <div class="flex flex-col items-start leading-none">
                <span class="font-black italic text-xl tracking-tighter uppercase text-white -skew-x-12">
                    FORMULA <span class="text-red-600">1</span>
                </span>
                <span class="text-[7px] font-mono text-zinc-500 uppercase tracking-[0.4em] ml-1">Archive Log</span>
            </div>
        </a>

        <div class="hidden md:flex items-center gap-6 text-[11px] font-black uppercase tracking-[0.2em]">
            <a href="/" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Inicio
            </a>
            <a href="/sprint" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Sprint
            </a>
            <a href="/estadistica" class="text-zinc-400 hover:text-white transition-all flex items-center gap-2 group/link">
                <span class="w-1 h-1 bg-zinc-800 group-hover:bg-red-600 rounded-full transition-colors"></span>
                Estadística
            </a>
            
            <div class="bg-zinc-800/50 border border-zinc-700 px-4 py-2 rounded-md">
                <span class="text-zinc-300 italic">History Active</span>
            </div>
        </div>

        <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 items-end group outline-none">
            <span class="w-8 h-[2px] bg-white group-hover:bg-red-600 transition-all origin-right" id="line1"></span>
            <span class="w-5 h-[2px] bg-red-600 group-hover:bg-white transition-all" id="line2"></span>
            <span class="w-8 h-[2px] bg-white group-hover:bg-red-600 transition-all origin-right" id="line3"></span>
        </button>
    </div>

    <div id="mobile-menu-content" class="fixed inset-0 top-[72px] bg-[#020c1b] z-[90] flex flex-col p-8 transition-all duration-500 translate-x-full md:hidden">
        <div class="flex flex-col gap-8">
            <span class="text-[9px] font-mono text-zinc-600 tracking-[0.5em] uppercase border-b border-zinc-900 pb-2">Archive Systems</span>
            
            <a href="/" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Inicio</a>
            <a href="/sprint" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Sprint</a>
            <a href="/estadistica" class="mobile-link text-4xl font-black italic uppercase text-white tracking-tighter">Estadística</a>
            
            <div class="mt-4 p-4 border-l-2 border-zinc-500 bg-white/5">
                <span class="text-[10px] font-mono text-zinc-500 uppercase tracking-widest block mb-1">Current Log:</span>
                <span class="text-xl font-black text-white italic uppercase">Season History</span>
            </div>
        </div>
        <div class="mt-auto opacity-10">
            <span class="text-[60px] font-black italic text-white leading-none">DATABASE</span>
        </div>
    </div>
</nav>

<script data-astro-rerun>
    document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu-content');
        const lines = [document.getElementById('line1'), document.getElementById('line2'), document.getElementById('line3')];

        if (!btn || !menu) return;

        const toggleMenu = () => {
            const isOpen = menu.classList.contains('translate-x-0');
            if (isOpen) {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                lines[0].style.transform = 'rotate(0) translateY(0)';
                lines[1].style.opacity = '1';
                lines[2].style.transform = 'rotate(0) translateY(0)';
            } else {
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                lines[0].style.transform = 'rotate(-45deg) translate(-5px, 5px)';
                lines[1].style.opacity = '0';
                lines[2].style.transform = 'rotate(45deg) translate(-5px, -5px)';
            }
        };

        btn.addEventListener('click', toggleMenu);
    });
</script>

<main class="max-w-5xl mx-auto pt-32 pb-20 px-4">
    <header id="inicio" class="mb-16 relative py-20 overflow-hidden "> 
    <img 
        src="/Fotos/fondo-f1.png" 
        class="absolute inset-0 w-full h-full object-cover opacity-20 z-0 pointer-events-none" 
        alt="Fondo Sprint"
        
    />
<div class="absolute inset-0 z-[1] bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-zinc-900/0 via-black/80 to-black pointer-events-none"></div>

    <div class="absolute inset-0 z-[2] opacity-[0.03] pointer-events-none bg-[url('data:image/svg+xml;base64,')] bg-center"></div>

    <div class="absolute top-10 left-10 w-16 h-16 border-t-2 border-l-2 border-zinc-800 pointer-events-none opacity-40"></div>
    <div class="absolute top-10 right-10 w-16 h-16 border-t-2 border-r-2 border-zinc-800 pointer-events-none opacity-40"></div>
    <div class="relative z-10 text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black uppercase italic tracking-tighter text-white -skew-x-15 leading-tight">
            HISTORIAL 
            <span class="block md:inline text-red-600 -skew-x-15 drop-shadow-[0_0_20px_rgba(220,38,38,0.6)]">
                CARRERAS
            </span>
        </h1>
        <div class="mt-8 mb-4 flex justify-center items-center gap-4 reveal-on-scroll">
            <span class="flex-1 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent max-w-[200px]"></span>
            <div class="flex items-center justify-center gap-1.5 bg-zinc-950 px-4 py-1.5 rounded-full border border-zinc-800 shadow-inner">
                <span class="w-1.5 h-1.5 bg-red-600 rounded-full animate-pulse"></span>
                <p class="text-zinc-400 font-mono text-[9px] uppercase tracking-[0.5em]">
                    RESULTADOS POR FECHA
                </p>
            </div>
            <span class="flex-1 h-[1px] bg-gradient-to-r from-transparent via-zinc-800 to-transparent max-w-[200px]"></span>
        </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-red-950 via-red-600 to-red-950 opacity-80 shadow-[0_0_20px_rgba(220,38,38,0.5)]"></div>
</header>

    {/* Aquí sigue el bucle {carreras.map(...) que ya armamos */}

    {carreras.map((carrera) => (
        <section class="mb-32 animate-fade-in">
            {/* Cabecera idéntica a tu diseño */}
            <div class="flex flex-col md:flex-row justify-between items-end border-b border-zinc-800 pb-6 mb-8 gap-4">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        <span class="bg-red-600 text-[10px] font-black px-2 py-0.5 rounded uppercase italic">GP {carrera.id}</span>
                        <span class="text-zinc-500 font-mono text-[10px] uppercase tracking-widest">{carrera.fecha}</span>
                    </div>
                    <h2 class="text-5xl font-black uppercase italic tracking-tighter">
                        {carrera.gp} <span class="text-zinc-500 text-2xl block md:inline md:ml-2 not-italic font-light">{carrera.circuito}</span>
                    </h2>
                </div>
                <div class="text-right">
                    <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-1">Duración Total</p>
                    <p class="font-black italic text-xl text-white">{carrera.duracion}</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
                {/* Columna de Imagen y Stats */}
                <div class="space-y-6">
                    <div class="relative group overflow-hidden rounded-2xl border border-zinc-800">
    <img 
        src={carrera.imagen} 
        alt={carrera.gp} 
        {/* aspect-video (16:9) en cel asegura que no se estire raro, y lg:h-54 mantiene tu tamaño de PC */}
        class="w-full aspect-video lg:aspect-none lg:h-54 object-cover transition-transform duration-500 group-hover:scale-110" 
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
</div>
                    
                    <div class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 space-y-4">
                        <div class="flex justify-between items-center">
                            <div>
                                <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-1">Pole Position</p>
                                <p class="text-xl font-black italic uppercase text-red-500">{carrera.pole}</p>
                            </div>
                            <p class="font-mono text-xs text-zinc-400">{carrera.tiempoPole}</p>
                        </div>
                        <div class="pt-4 border-t border-zinc-800 flex justify-between items-center">
                            <div>
                                <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-1">Vuelta Rápida</p>
                                <p class="text-xl font-black italic uppercase text-blue-500">{carrera.vueltaRapida}</p>
                            </div>
                            <p class="font-mono text-xs text-zinc-400">{carrera.tiempoVR}</p>
                        </div>
                    </div>
                </div>

                {/* Tabla de Resultados - Tal cual la tenías en el PDF */}
                <div class="lg:col-span-2">
                    <div class="bg-zinc-900/30 rounded-2xl border border-zinc-800 overflow-hidden">
                    
                        <table class="w-full text-left border-collapse">
                    
                            <thead class="bg-zinc-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest">Pos</th>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest">Piloto / Escudería</th>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest text-center">Info</th>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest text-right">PTS</th>
                                </tr>
                            </thead>
                    
                           <tbody class="divide-y divide-zinc-800/50">
    {/* Aplicamos el sort para ordenar de menor a mayor por el campo 'pos' */}
    {carrera.resultados.sort((a, b) => a.pos - b.pos).map((res) => {
        const info = obtenerInfoPiloto(res.piloto);
        return (
            <tr class="hover:bg-zinc-800/20 transition-colors group">
                <td class="px-6 py-5 font-black italic text-2xl text-zinc-500 group-hover:text-red-500">
                    {res.pos}
                </td>
                <td class="px-6 py-5">
                    <div class="flex items-center gap-4">
                        <img 
                                src={`/Fotos/perfil-${res.piloto.toLowerCase()}.jpg`} 
                                class="w-16 h-16 rounded-full object-cover border-2 border-zinc-800 group-hover:border-red-600 transition-all duration-300 group-hover:scale-110 animate-latido"
                                alt={res.piloto}
                            />
                        <img src={logos[info.escuderia]} class="w-8 opacity-50" />
                        <div>
                            <p class="font-black uppercase italic text-lg">{res.piloto}</p>
                            <p class="text-[10px] text-zinc-500 font-mono uppercase">{info.escuderia}</p>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-5 text-center">
                    <div class="flex gap-2 justify-center">
                        {res.piloto === carrera.pole && (
                            <span class="bg-red-600/20 text-red-500 text-[9px] px-2 py-0.5 rounded font-black border border-red-600/30">P</span>
                        )}
                        {res.nota === "VR" && (
                            <span class="bg-blue-600/20 text-blue-500 text-[9px] px-2 py-0.5 rounded font-black border border-blue-600/30">VR</span>
                        )}
                    </div>
                </td>
                <td class="px-6 py-5 text-right font-mono font-black text-2xl italic text-zinc-300">
                    {res.puntos}
                </td>
            </tr>
        );
    })}
</tbody>
                        </table>
                        
                        {/* El pie de tabla que tenías al final de la página 7 */}
                        <div class="bg-zinc-800/30 py-3 px-6 text-center border-t border-zinc-800/50">
                            <p class="text-[9px] text-zinc-600 font-mono uppercase tracking-[0.3em]">Puntaje Oficial de la Fecha</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    ))}

    {/* Tu galería de resultados (página 7 del PDF) va acá abajo fuera del loop */}
</main>


<section id="galeria-historial" class="mt-20 pb-20 px-4 max-w-6xl mx-auto">
    <div class="reveal-on-scroll text-center mb-16">
        <h2 class="text-sm font-black mb-4 uppercase tracking-[0.4em] text-zinc-400">
            Datos <span class="text-red-600">Carreras</span> Archivos
        </h2>
        <h3 class="text-4xl font-black uppercase italic text-white tracking-tighter">
            GALERÍA DE <span class="text-red-600">RESULTADOS</span>
        </h3>
    </div>

    <div class="space-y-24">
        {fechas.map((f) => (
            <div class="reveal-item group relative" style={`transition-delay: 100ms;`}>
                
                <div class="absolute -left-4 md:-left-12 top-0 flex flex-col items-center">
                    <span class="text-[10px] font-black text-zinc-600 uppercase tracking-[0.5em] rotate-180" style="writing-mode: vertical-rl;">
                        SEASON 2025
                    </span>
                    <div class="w-[1px] h-20 bg-zinc-800 my-4"></div>
                    <span class="text-2xl font-mono font-black text-red-600 italic">
                        {f < 10 ? `0${f}` : f}
                    </span>
                </div>

                <div class="ml-8 md:ml-0 bg-[#020c1b]/50 border border-zinc-900 rounded-xl overflow-hidden hover:border-red-600/30 transition-all duration-500 shadow-2xl">
                    
                    <div class="bg-zinc-950 px-6 py-4 border-b border-zinc-900 flex justify-between items-center">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></div>
                            <h4 class="text-xs font-black uppercase tracking-widest text-zinc-300">
                                DATA: <span class="text-white">FECHA {f}</span>
                            </h4>
                        </div>
                        <span class="text-[10px] font-mono text-zinc-600">STATUS: ARCHIVED_CONFIRMED</span>
                    </div>

                    <div class="relative p-2 md:p-4 bg-zinc-900/20">
                        <div class="absolute top-6 left-6 w-8 h-8 border-t-2 border-l-2 border-red-600/50 z-20"></div>
                        <div class="absolute bottom-6 right-6 w-8 h-8 border-b-2 border-r-2 border-red-600/50 z-20"></div>

                        <div class="relative overflow-hidden rounded-lg">
                            <img 
                                src={`/Fotos/resultados-fecha${f}.jpg`} 
                                class="w-full h-auto object-contain max-h-[80vh] transition-transform duration-700 group-hover:scale-[1.01]" 
                                alt={`Resultados Oficiales Fecha ${f}`}
                                loading="lazy"
                            />
                            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-red-600/[0.02] to-transparent h-[200%] w-full -translate-y-full group-hover:animate-[scan_4s_linear_infinite] pointer-events-none"></div>
                        </div>
                    </div>

                    <div class="px-6 py-3 bg-zinc-950/80 text-right">
                        <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest">
                            Verified by Race Control // LC-VT-2025-{f}
                        </p>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    .vertical-text {
        writing-mode: vertical-rl;
    }

    @keyframes scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(200%); }
    }
</style>
    </body>
</html>