---
// Mantener los imports iguales arriba
import '../styles/global.css';
import pilotos from '../Data/pilotos.json';
import historial from '../Data/historial.json';
import { ClientRouter } from 'astro:transitions';
const carreras = [...historial].reverse();
const logos = {
  "Mercedes Benz": "/Fotos/logo-mercedes.png",
  "Alpine": "/Fotos/logo-alpine.png",
  "Red Bull": "/Fotos/logo-redbull.png",
  "Ferrari": "/Fotos/logo-ferrari.png",
  "Williams": "/Fotos/logo-williams.png",
};

const obtenerInfoPiloto = (nombre) => {
    return pilotos.find(p => p.nombre === nombre) || { escuderia: "S/D" };
};
---

<style>
    .show-dropdown {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) !important;
    }
    .rotate-arrow {
        transform: rotate(180deg) !important;
    }
@keyframes latido {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.25); /* Se agranda un 10% */
  }
}

.animate-latido {
  animation: latido 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes latido-pro {
  0%, 100% {
    transform: scale(1);
    filter: grayscale(10%) opacity(50%) blur(1px);
    /* Sombra tenue cuando está "apagado" */
    filter: drop-shadow(0 0 0px rgba(0,0,0,0));
  }
  50% {
    transform: scale(1.25); /* Se agranda un 15% */
    filter: grayscale(0%) opacity(100%) blur(0px);
    /* Brillo rojo estilo F1 cuando se agranda */
    filter: drop-shadow(0 0 15px rgba(220, 38, 38, 0.6));
  }
}

.animate-latido-color {
  animation: latido-pro 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}


</style>



<html lang="es">
    <head>
       <meta charset="utf-8" />
    <title>Historial - Liga F1 Chocapinto</title>
    <ClientRouter /> </head>
</head>
    <body class="bg-slate-950 text-white font-sans">
        
        <nav class="fixed top-0 w-full bg-zinc-900/80 backdrop-blur-md border-b border-zinc-800 z-50">
            <div class="max-w-5xl mx-auto px-6 py-5 flex justify-between items-center">
                <a href="/" class="font-black italic text-xl tracking-tighter uppercase text-white -skew-x-15">
                    FORMULA <span class="text-red-600">1</span>
                </a>
                <a href="/sprint" class="text-zinc-100 font-black text-x ">SRINT</a>
                <a href="/" class="text-xs font-black uppercase tracking-widest hover:text-red-500 transition-colors">← Volver al Inicio</a>
            </div>
        </nav>

<main class="max-w-5xl mx-auto pt-32 pb-20 px-4">
    <header class="mb-16 relative py-20 overflow-hidden border-b-4 border-red-950"> 
        {/* IMAGEN DE FONDO */}
        <img 
            src="/Fotos/fondo-f1.png" 
            class="absolute inset-0 w-full h-full object-cover opacity-20 z-0 pointer-events-none" 
            alt="Fondo F1"
        />

        {/* CONTENIDO CENTRADO */}
        <div class="relative z-10 text-center">
            <h1 class="text-5xl font-black uppercase italic tracking-tighter text-white -skew-x-15">
                Historial de <span class="text-red-600 -skew-x-15">Carreras</span>
            </h1>
            <p class="text-zinc-300 font-mono text-xs uppercase tracking-[0.4em] mt-2">
                Resultados por fecha
            </p>
        </div>
    </header>

    {/* Aquí sigue el bucle {carreras.map(...) que ya armamos */}

    {carreras.map((carrera) => (
        <section class="mb-32 animate-fade-in">
            {/* Cabecera idéntica a tu diseño */}
            <div class="flex flex-col md:flex-row justify-between items-end border-b border-zinc-800 pb-6 mb-8 gap-4">
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        <span class="bg-red-600 text-[10px] font-black px-2 py-0.5 rounded uppercase italic">GP {carrera.id}</span>
                        <span class="text-zinc-500 font-mono text-[10px] uppercase tracking-widest">{carrera.fecha}</span>
                    </div>
                    <h2 class="text-5xl font-black uppercase italic tracking-tighter">
                        {carrera.gp} <span class="text-zinc-500 text-2xl block md:inline md:ml-2 not-italic font-light">{carrera.circuito}</span>
                    </h2>
                </div>
                <div class="text-right">
                    <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-1">Duración Total</p>
                    <p class="font-black italic text-xl text-white">{carrera.duracion}</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
                {/* Columna de Imagen y Stats */}
                <div class="space-y-6">
                    <div class="relative group overflow-hidden rounded-2xl border border-zinc-800">
    <img 
        src={carrera.imagen} 
        alt={carrera.gp} 
        {/* aspect-video (16:9) en cel asegura que no se estire raro, y lg:h-54 mantiene tu tamaño de PC */}
        class="w-full aspect-video lg:aspect-none lg:h-54 object-cover transition-transform duration-500 group-hover:scale-110" 
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
</div>
                    
                    <div class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 space-y-4">
                        <div class="flex justify-between items-center">
                            <div>
                                <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-1">Pole Position</p>
                                <p class="text-xl font-black italic uppercase text-red-500">{carrera.pole}</p>
                            </div>
                            <p class="font-mono text-xs text-zinc-400">{carrera.tiempoPole}</p>
                        </div>
                        <div class="pt-4 border-t border-zinc-800 flex justify-between items-center">
                            <div>
                                <p class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-1">Vuelta Rápida</p>
                                <p class="text-xl font-black italic uppercase text-blue-500">{carrera.vueltaRapida}</p>
                            </div>
                            <p class="font-mono text-xs text-zinc-400">{carrera.tiempoVR}</p>
                        </div>
                    </div>
                </div>

                {/* Tabla de Resultados - Tal cual la tenías en el PDF */}
                <div class="lg:col-span-2">
                    <div class="bg-zinc-900/30 rounded-2xl border border-zinc-800 overflow-hidden">
                    
                        <table class="w-full text-left border-collapse">
                    
                            <thead class="bg-zinc-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest">Pos</th>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest">Piloto / Escudería</th>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest text-center">Info</th>
                                    <th class="px-6 py-4 text-[10px] font-mono text-zinc-400 uppercase tracking-widest text-right">PTS</th>
                                </tr>
                            </thead>
                    
                           <tbody class="divide-y divide-zinc-800/50">
    {/* Aplicamos el sort para ordenar de menor a mayor por el campo 'pos' */}
    {carrera.resultados.sort((a, b) => a.pos - b.pos).map((res) => {
        const info = obtenerInfoPiloto(res.piloto);
        return (
            <tr class="hover:bg-zinc-800/20 transition-colors group">
                <td class="px-6 py-5 font-black italic text-2xl text-zinc-500 group-hover:text-red-500">
                    {res.pos}
                </td>
                <td class="px-6 py-5">
                    <div class="flex items-center gap-4">
                        <img 
                                src={`/Fotos/perfil-${res.piloto.toLowerCase()}.jpg`} 
                                class="w-16 h-16 rounded-full object-cover border-2 border-zinc-800 group-hover:border-red-600 transition-all duration-300 group-hover:scale-110 animate-latido"
                                alt={res.piloto}
                            />
                        <img src={logos[info.escuderia]} class="w-8 opacity-50" />
                        <div>
                            <p class="font-black uppercase italic text-lg">{res.piloto}</p>
                            <p class="text-[10px] text-zinc-500 font-mono uppercase">{info.escuderia}</p>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-5 text-center">
                    <div class="flex gap-2 justify-center">
                        {res.piloto === carrera.pole && (
                            <span class="bg-red-600/20 text-red-500 text-[9px] px-2 py-0.5 rounded font-black border border-red-600/30">P</span>
                        )}
                        {res.nota === "VR" && (
                            <span class="bg-blue-600/20 text-blue-500 text-[9px] px-2 py-0.5 rounded font-black border border-blue-600/30">VR</span>
                        )}
                    </div>
                </td>
                <td class="px-6 py-5 text-right font-mono font-black text-2xl italic text-zinc-300">
                    {res.puntos}
                </td>
            </tr>
        );
    })}
</tbody>
                        </table>
                        
                        {/* El pie de tabla que tenías al final de la página 7 */}
                        <div class="bg-zinc-800/30 py-3 px-6 text-center border-t border-zinc-800/50">
                            <p class="text-[9px] text-zinc-600 font-mono uppercase tracking-[0.3em]">Puntaje Oficial de la Fecha</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    ))}

    {/* Tu galería de resultados (página 7 del PDF) va acá abajo fuera del loop */}
</main>
<h2 class="text-2xl font-black uppercase italic mb-6 text-center">
    Galería de <span class="text-red-600">Resultados</span>
</h2>


<section class="mt-20 pt-10 border-t border-zinc-800 px-4">
   <h2 class="text-2xl font-black uppercase italic mb-6">Fecha<span class="text-red-600">3</span></h2>
    
    <div class="relative group w-full max-w-[90%] mx-auto"> 
        <div id="slider-resultados" class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar scroll-smooth rounded-xl bg-zinc-900/50">
            
            <div class="min-w-full snap-center flex justify-center items-center">
                <img 
                    src="/Fotos/resultados-fecha3.jpg" 
                    class="w-full h-auto max-h-[80vh] object-contain rounded-xl border border-zinc-800 shadow-2xl" 
                    alt="Resultados Fecha 1" 
                />
             </div>           
            
        </div>
    </div>
</section>

<section class="mt-20 pt-10 border-t border-zinc-800 px-4">
   <h2 class="text-2xl font-black uppercase italic mb-6">Fecha<span class="text-red-600">2</span></h2>
    
    <div class="relative group w-full max-w-[90%] mx-auto"> 
        <div id="slider-resultados" class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar scroll-smooth rounded-xl bg-zinc-900/50">
            
            <div class="min-w-full snap-center flex justify-center items-center">
                <img 
                    src="/Fotos/resultados-fecha2.jpg" 
                    class="w-full h-auto max-h-[80vh] object-contain rounded-xl border border-zinc-800 shadow-2xl" 
                    alt="Resultados Fecha 1" 
                />
             </div>           
            
        </div>
    </div>
</section>
        <section class="mt-20 pt-10 border-t border-zinc-800 px-4">
   <h2 class="text-2xl font-black uppercase italic mb-6">Fecha <span class="text-red-600">1</span></h2>
    
    <div class="relative group w-full max-w-[90%] mx-auto"> 
        <div id="slider-resultados" class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar scroll-smooth rounded-xl bg-zinc-900/50">
            
            <div class="min-w-full snap-center flex justify-center items-center">
                
                <img 
                    src="/Fotos/resultados-fecha1.jpg" 
                    class="w-full h-auto max-h-[80vh] object-contain rounded-xl border border-zinc-800 shadow-2xl" 
                    alt="Resultados Fecha 1" 
                />
            </div>           
            
        </div>
    </div>
</section>
    </body>
</html>