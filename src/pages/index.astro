            </ul>
        </div>

        <div class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 group hover:border-red-600/30 transition-colors">
            <div class="flex items-center gap-3 mb-4">
                <div class="p-2 bg-blue-600/10 rounded-lg">
                    <span class="text-blue-500">🛠️</span>
                </div>
                <h4 class="font-black uppercase italic text-sm tracking-tighter">Asistencias</h4>
            </div>
            <div class="space-y-4">
                <div>
                    <p class="text-[10px] text-red-500 font-black uppercase tracking-widest mb-1">Prohibidas</p>
                    <p class="text-xs text-zinc-400 leading-relaxed font-bold">Trazada Dinámica Desactivada</p>
                </div>
                <div>
                    <p class="text-[10px] text-blue-500 font-black uppercase tracking-widest mb-1">Libre Elección</p>
                    <p class="text-xs text-zinc-400 leading-relaxed">ABS, Tracción, Caja de cambios, ERS y DRS</p>
                </div>
            </div>
        </div>

        <div class="bg-zinc-900/50 p-6 rounded-2xl border border-zinc-800 group hover:border-red-600/30 transition-colors">
            <div class="flex items-center gap-3 mb-4">
                <div class="p-2 bg-yellow-600/10 rounded-lg">
    <span class="text-yellow-500 text-xl">🚓</span>
</div>
                <h4 class="font-black uppercase italic text-sm tracking-tighter">Varios</h4>
            </div>
            <ul class="space-y-3 text-sm font-medium">
                <li class="flex justify-between border-b border-zinc-800/50 pb-2 text-xs">
                    <span class="text-zinc-500 italic">Safety Car:</span>
                    <span class="text-white font-bold">Activado</span>
                </li>
                <li class="flex justify-between border-b border-zinc-800/50 pb-2 text-xs">
                    <span class="text-zinc-500 italic">Formación:</span>
                    <span class="text-white font-bold">Obligatoria</span>
                </li>
                <li class="flex justify-between text-xs">
                    <span class="text-zinc-500 italic">Cámara:</span>
                    <span class="text-white font-bold uppercase tracking-tighter">Libre</span>
                </li>
            </ul>
        </div>
		</div>
   <div class="mt-8 flex justify-center">
    <p class="inline-flex items-center gap-2 bg-yellow-600/10 px-6 py-2 rounded-full border border-yellow-600/20 text-[11px] text-yellow-500 font-mono font-black uppercase tracking-[0.2em] animate-pulse">
        <span>⚠️</span> 
        Cuidado extremo con el ala y el fondo plano. Daños en modo simulación. No sean bots.
    </p>
</div>
<div class="mt-12 pt-12 border-t border-zinc-800"></div>

            </section>

        </main>

        <div class="fixed bottom-6 right-6 z-50">
            <button id="musicaBtn" class="bg-red-600 hover:bg-red-700 text-white w-14 h-14 rounded-full shadow-2xl transition-all hover:scale-110 flex items-center justify-center border-2 border-white/20">
                <span id="iconoMusica" class="text-xl">▶️</span>
            </button>
        </div>

        <audio id="musicaFondo" loop>
            <source src="/cancion-ligaf1.mp3" type="audio/mpeg">
        </audio>

        <script>
            const btn = document.getElementById('musicaBtn');
            const audio = document.getElementById('musicaFondo');
            const icono = document.getElementById('iconoMusica');

            btn.addEventListener('click', () => {
                if (audio.paused) {
                    audio.play();
                    icono.innerText = '⏸️'; 
                    btn.classList.add('animate-pulse');
                } else {
                    audio.pause();
                    icono.innerText = '▶️';
                    btn.classList.remove('animate-pulse');
                }
            });
        </script>
    </body>
</html>