---
import pilotos from '../data/pilotos.json';
import '../styles/global.css';

const logos = {
  "Mercedes Benz": "/Fotos/logo-mercedes.png",
  "Alpine": "/Fotos/logo-alpine.png",
  "Red Bull": "/Fotos/logo-redbull.png"
};

const escuderiasMap = pilotos.reduce((acc, piloto) => {
    if (!acc[piloto.escuderia]) {
        acc[piloto.escuderia] = { nombre: piloto.escuderia, puntos: 0 };
    }
    acc[piloto.escuderia].puntos += piloto.puntos;
    return acc;
}, {});

const escuderias = Object.values(escuderiasMap).sort((a, b) => b.puntos - a.puntos);
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <title>Liga F1 - Los Chocapinto</title>
    </head>
    <body class="bg-zinc-950 text-white font-sans">
        <main class="max-w-4xl mx-auto py-10 px-4">
            
            <header class="border-b-4 border-red-600 mb-12 pb-6 flex justify-between items-end">
                <div>
                    <h1 class="text-6xl font-black uppercase tracking-tighter italic">Liga F1 <span class="text-red-600">Los Chocapinto</span></h1>
                    <p class="text-zinc-500 font-mono mt-2 tracking-[0.2em] text-sm">VENADO TUERTO</p>
                </div>
            </header>

            <section class="mb-16">
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 uppercase tracking-tight">
                    <span class="w-2 h-8 bg-red-600 inline-block"></span> Driver Standings
                </h2>
                <div class="bg-zinc-900 rounded-xl overflow-hidden border border-zinc-800 shadow-2xl">
                    <table class="w-full text-left">
                        <thead class="bg-zinc-800 text-zinc-400 uppercase text-[11px] tracking-widest">
                            <tr>
                                <th class="px-6 py-4 text-center">Pos</th>
                                <th class="px-6 py-4">Piloto</th>
                                <th class="px-6 py-4 text-center">🏆 Vic</th>
                                <th class="px-6 py-4 text-right">PTS</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-zinc-800">
                            {pilotos.sort((a, b) => b.puntos - a.puntos).map((piloto, index) => (
                                <tr class="hover:bg-zinc-800/40 transition-all group">
                                    <td class="px-6 py-6 font-black text-3xl italic text-zinc-800 group-hover:text-red-600 text-center w-24 leading-none">{index + 1}</td>
                                    <td class="px-6 py-6">
                                        <div class="flex items-center gap-6">
                                            <img src={logos[piloto.escuderia]} alt={piloto.escuderia} class="w-12 h-12 object-contain" />
                                            <div>
                                                <div class="font-black text-zinc-100 text-xl uppercase tracking-tighter">{piloto.nombre}</div>
                                                <div class="text-[10px] text-zinc-500 font-bold tracking-widest uppercase">{piloto.escuderia}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-6 text-center">
                                        <span class={piloto.victorias > 0 ? "text-yellow-500 text-xl font-black" : "text-zinc-800 text-xl font-black"}>
                                            {piloto.victorias}
                                        </span>
                                    </td>
                                    <td class="px-6 py-6 text-right">
                                        <span class="bg-zinc-950 px-5 py-2 rounded-md text-white font-mono font-black border border-zinc-700 text-xl group-hover:border-red-600">
                                            {piloto.puntos}
                                        </span>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </section>

            <section>
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 uppercase tracking-tight">
                    <span class="w-2 h-8 bg-zinc-400 inline-block"></span> Constructors
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    {escuderias.map((team, index) => (
                        <div 
                            class="bg-zinc-900 p-8 rounded-xl border-t-4 border border-zinc-800 flex flex-col items-center justify-center relative overflow-hidden group shadow-lg" 
                            style={`border-top-color: ${
                                team.nombre === 'Mercedes Benz' ? '#62f5d7' : 
                                team.nombre === 'Red Bull' ? '#1e40af' : 
                                '#00a3a3'
                            }`}
                        >
                            <img src={logos[team.nombre]} alt={team.nombre} class="w-20 h-20 object-contain mb-6 transition-transform group-hover:scale-110" />
                            <h3 class="text-xl font-black uppercase z-10 tracking-tighter">{team.nombre}</h3>
                            <p class="text-5xl font-mono font-black mt-2 text-white z-10">{team.puntos}</p>
                            <div class="absolute -bottom-2 -right-2 text-7xl font-black text-zinc-800 opacity-20 italic">#{index + 1}</div>
                        </div>
                    ))}
                </div>
            </section>

        </main>
    </body>
</html>