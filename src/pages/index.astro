<script data-astro-rerun>
    document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu-content');
        const lines = [document.getElementById('line1'), document.getElementById('line2'), document.getElementById('line3')];
        const links = document.querySelectorAll('.mobile-link');

        if (!btn || !menu) return;

        const toggleMenu = () => {
            const isOpen = menu.classList.contains('translate-x-0');
            
            if (isOpen) {
                // Cerrar
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                lines[0].style.transform = 'rotate(0) translateY(0)';
                lines[1].style.opacity = '1';
                lines[2].style.transform = 'rotate(0) translateY(0)';
            } else {
                // Abrir
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                lines[0].style.transform = 'rotate(-45deg) translate(-5px, 5px)';
                lines[1].style.opacity = '0';
                lines[2].style.transform = 'rotate(45deg) translate(-5px, -5px)';
            }
        };

        btn.addEventListener('click', toggleMenu);

        // Cerrar menú al hacer clic en un link
        links.forEach(link => {
            link.addEventListener('click', () => {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                lines[0].style.transform = 'rotate(0) translateY(0)';
                lines[1].style.opacity = '1';
                lines[2].style.transform = 'rotate(0) translateY(0)';
            });
        });
    });
</script>

<style>
    .show-dropdown {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) !important;
    }
    .rotate-arrow {
        transform: rotate(180deg) !important;
    }
@keyframes latido {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1); /* Se agranda un 10% */
  }
}

.animate-latido {
  animation: latido 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes latido-pro {
  0%, 100% {
    transform: scale(1);
    filter: grayscale(10%) opacity(50%) blur(1px);
    /* Sombra tenue cuando está "apagado" */
    filter: drop-shadow(0 0 0px rgba(0,0,0,0));
  }
  50% {
    transform: scale(1.25); /* Se agranda un 15% */
    filter: grayscale(0%) opacity(100%) blur(0px);
    /* Brillo rojo estilo F1 cuando se agranda */
    filter: drop-shadow(0 0 15px rgba(220, 38, 38, 0.6));
  }
}

.animate-latido-color {
  animation: latido-pro 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}


</style>

<script>
    // Usamos 'astro:page-load' para que el script se reactive tras cada navegación
    document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('btn-historial');
        const menu = document.getElementById('menu-historial');
        const flecha = document.getElementById('flecha-historial');

        if (!btn || !menu || !flecha) return;

        // Función para cerrar el menú
        const cerrarMenu = () => {
            menu.classList.remove('show-dropdown');
            flecha.classList.remove('rotate-arrow');
        };

        // Escuchamos el click directamente en el botón
        btn.addEventListener('click', (e) => {
            // Solo aplicamos la lógica manual si es pantalla táctil/chica
            if (window.innerWidth < 1024) {
                e.preventDefault();
                e.stopPropagation();
                menu.classList.toggle('show-dropdown');
                flecha.classList.toggle('rotate-arrow');
            }
        });

        // Cerrar si se hace click en cualquier otra parte de la pantalla
        document.addEventListener('click', (e) => {
            if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
                cerrarMenu();
            }
        });

        // Cerrar si se presiona una opción del menú (opcional)
        menu.addEventListener('click', () => {
            if (window.innerWidth < 1024) {
                cerrarMenu();
            }
        });
    });
</script>



