        <div class="flex gap-8 text-[12px] font-black uppercase tracking-[0.2em]">
            <a href="#inicio" class="hover:text-red-500 transition-colors">Inicio</a>
            <a href="#pilotos" class="hover:text-red-500 transition-colors">Pilotos</a>
            <a href="#constructores" class="hover:text-red-500 transition-colors">Equipos</a>
            <a href="#puntaje" class="hover:text-red-500 transition-colors">Puntaje</a>
            <a href="#Configuración" class="hover:text-red-500 transition-colors">Configuración</a>
			<a href="/historial" class="hover:text-red-500 transition-colors">Historial</a>       
		</div>
    </div>
</nav>

