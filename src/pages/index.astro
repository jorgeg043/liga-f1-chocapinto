            </td>
            <td class="px-4 py-6 text-center font-bold text-zinc-400">
                {piloto.vueltasRapidas > 0 ? <span class="text-blue-500">{piloto.vueltasRapidas}</span> : "0"}
            </td>
            <td class="px-6 py-6 text-right">
                <span class="font-mono font-black text-xl text-white italic">
                    {piloto.puntos}
                </span>
            </td>
        </tr>
    ))}
</tbody>
                    </table>
                </div>
            </section>

            <section id="constructores" class="mb-20 scroll-mt-32">
                <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 uppercase tracking-tight">
                    <span class="w-2 h-8 bg-zinc-400 inline-block"></span> Campeonato Equipos
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    {escuderias.map((team, index) => (
                        <div class="bg-zinc-900 p-8 rounded-xl border border-zinc-800 flex flex-col items-center justify-center relative overflow-hidden group shadow-lg">
                            <img src={logos[team.nombre]} alt={team.nombre} class="w-20 h-20 object-contain mb-6 transition-transform group-hover:scale-110" />
                            <h3 class="text-xl font-black uppercase z-10 tracking-tighter text-white">{team.nombre}</h3>
                            <p class="text-5xl font-mono font-black mt-2 text-red-600 z-10 italic">{team.puntos}</p>
                            <div class="absolute -bottom-2 -right-2 text-7xl font-black text-zinc-800 opacity-20 italic">#{index + 1}</div>
                        </div>
                    ))}
                </div>
            </section>

            <section id="puntaje" class="scroll-mt-32 mb-20">
                <h2 class="text-sm font-black mb-8 uppercase tracking-[0.3em] text-zinc-400 flex items-center gap-4 text-center">
                    <span class="flex-1 h-[1px] bg-zinc-800"></span> ESQUEMA DE PUNTAJE <span class="flex-1 h-[1px] bg-zinc-800"></span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="bg-zinc-900/50 p-8 rounded-2xl border border-zinc-800">
                        <h3 class="text-red-600 font-black uppercase italic mb-4">Puntos por Carrera</h3>
                        <div class="grid grid-cols-2 gap-y-2 font-mono text-sm uppercase">
                            <div class="text-zinc-500">1° Puesto:</div><div class="text-right font-black">25 PTS</div>
                            <div class="text-zinc-500">2° Puesto:</div><div class="text-right font-black">18 PTS</div>
