</div>


</section>


			<section id="integrantes" class="mt-32 pb-20 scroll-mt-32">
    <h2 class="text-2xl font-bold mb-10 flex items-center gap-4 uppercase tracking-tighter w-full">
    <span class="flex-1 h-[1px] bg-zinc-800"></span>
    
    <span class="shrink-0">
        INTEGRANTES <span class="text-red-600">2026</span>
    </span>

    <span class="flex-1 h-[1px] bg-zinc-800"></span>
</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {(() => {
            // ORDEN CORREGIDO POR COLUMNAS:
            // Col 1: Chor y Franco (Alpine)
            // Col 2: Simon y Diego (Mercedes Benz)
            // Col 3: Rodri y Leo (Red Bull)
            const ordenDeseado = ["Chor", "Simon", "Rodri", "Franco", "Diego", "Leo"];
            
            const pilotosOrdenados = [...pilotos].sort((a, b) => {
                return ordenDeseado.indexOf(a.nombre) - ordenDeseado.indexOf(b.nombre);
            });

            return pilotosOrdenados.map((piloto) => {
                const fondoEscuderia = piloto.escuderia === "Mercedes Benz" ? "escuderia-mercedes.jpg" : 
                                     piloto.escuderia === "Alpine" ? "escuderia-alpine.jpg" : 
                                     "escuderia-redbull.jpg";
                
                return (
                    <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-6 transition-all duration-300 ease-out hover:scale-110 hover:z-50 hover:border-red-600/50 hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)] group relative overflow-hidden cursor-default transform-gpu will-change-transform">
                        
                        <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
                            <img 
                                src={`/Fotos/${fondoEscuderia}`} 
                                alt="" 
                                class="w-full h-full object-cover opacity-[0.07] group-hover:opacity-[0.35] transition-opacity duration-500 grayscale group-hover:grayscale-0"
                            />
                        </div>

                        <div class="relative z-10">
                            <div class="absolute -top-1 -right-1 text-[9px] font-black uppercase tracking-widest text-zinc-600 group-hover:text-red-500 transition-colors">
                                {piloto.nombre === "Chor" || piloto.nombre === "Simon" || piloto.nombre === "Rodri" ? "Piloto 1" : "Piloto 2"}
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 flex-shrink-0 bg-zinc-950 rounded-xl border border-zinc-800 p-2 flex items-center justify-center shadow-lg">
                                    <img src={logos[piloto.escuderia]} alt={piloto.escuderia} class="w-full h-full object-contain opacity-80 group-hover:opacity-100 transition-opacity" />
                                </div>

                                <div class="flex-1">
                                    <h3 class="text-xl font-black uppercase italic tracking-tighter text-white leading-none mb-1 group-hover:text-red-100 transition-colors">
                                        {piloto.nombre}
                                    </h3>
                                    <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest mb-4 italic">
                                        {piloto.escuderia}
                                    </p>

                                    <div class="flex items-center gap-2 mb-4 bg-zinc-950/80 w-fit px-3 py-1.5 rounded-lg border border-zinc-800 shadow-inner">
                                        <span class="flex items-center justify-center">
                                            {piloto.nombre === "Chor" ? (
                                                <svg class="w-4 h-4 text-zinc-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="12" cy="12" r="10" /><line x1="12" y1="2" x2="12" y2="12" /><line x1="12" y1="12" x2="4" y2="18" /><line x1="12" y1="12" x2="20" y2="18" /><circle cx="12" cy="12" r="2" fill="currentColor" />
                                                </svg>
                                            ) : piloto.nombre === "Franco" ? (
                                                <span class="text-sm">⌨️</span>
                                            ) : (
                                                <span class="text-sm">🎮</span>
                                            )}
                                        </span>
                                        <span class="text-[10px] font-mono text-zinc-300 uppercase font-bold">
                                            {piloto.nombre === "Chor" ? "Volante" : 
                                             piloto.nombre === "Franco" ? "Teclado" : "Joystick"}
                                        </span>
                                    </div>

                                    <a 
                                        href={
                                            piloto.nombre === "Chor" ? "https://www.instagram.com/jorgegiovagnoli/" :
                                            piloto.nombre === "Diego" ? "https://www.instagram.com/diiego.z_21" :
                                            piloto.nombre === "Simon" ? "https://www.instagram.com/pablosimon23/" :
                                            piloto.nombre === "Franco" ? "https://www.instagram.com/francobellisonzi/" :
                                            piloto.nombre === "Rodri" ? "https://www.instagram.com/roodribarros/" :
                                            "https://www.instagram.com/leo.tapparello/"
                                        } 
                                        target="_blank" 
