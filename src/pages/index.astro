    <script>
  const btnHistorial = document.getElementById('btn-historial');
  const menuHistorial = document.getElementById('menu-historial');
  const flecha = document.getElementById('flecha-historial');

  btnHistorial.addEventListener('click', (e) => {
    // Evitamos que el click se propague si es necesario
    e.stopPropagation();
    
    // Toggle de clases para mostrar/ocultar
    const isOpen = menuHistorial.classList.contains('opacity-100');
    
    if (isOpen) {
      menuHistorial.classList.remove('opacity-100', 'visible', 'translate-y-0');
      menuHistorial.classList.add('opacity-0', 'invisible', 'translate-y-2');
      flecha.style.transform = 'rotate(0deg)';
    } else {
      menuHistorial.classList.remove('opacity-0', 'invisible', 'translate-y-2');
      menuHistorial.classList.add('opacity-100', 'visible', 'translate-y-0');
      flecha.style.transform = 'rotate(180deg)';
    }
  });

  // Cerrar el menú si hacés click afuera (muy importante para mobile)
  document.addEventListener('click', () => {
    menuHistorial.classList.remove('opacity-100', 'visible', 'translate-y-0');
    menuHistorial.classList.add('opacity-0', 'invisible', 'translate-y-2');
    flecha.style.transform = 'rotate(0deg)';
  });
</script>
