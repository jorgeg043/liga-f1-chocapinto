<style is:global>
    .draw-line-h { animation: drawH 0.2s forwards linear; }
    .draw-line-v { animation: drawV 0.4s forwards linear; }

    @keyframes drawH {
        from { width: 0; opacity: 1; }
        to { width: 100%; opacity: 1; }
    }

    @keyframes drawV {
        from { height: 0; opacity: 1; }
        to { height: 100%; opacity: 1; }
